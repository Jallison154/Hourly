// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id                         String   @id @default(cuid())
  name                       String   @default("Hourly Company")
  logoUrl                    String?
  timezone                   String   @default("America/Denver")
  workWeekStartDay           Int      @default(0) // 0=Sunday … 6=Saturday
  overtimeThresholdMinutes   Int      @default(2400) // 40 hours
  overtimeMultiplier         Float    @default(1.5)
  defaultPayPeriodType       String   @default("monthly") // weekly | monthly
  payPeriodEndDay            Int      @default(10)
  longShiftWarningMinutes    Int      @default(720) // 12 hours
  allowEmployeeManualEntries Boolean  @default(true)
  allowEmployeeEditing       Boolean  @default(true)
  requireTimesheetApproval   Boolean  @default(false)
  registrationEnabled        Boolean  @default(true)
  paycheckEstimatesEnabled   Boolean  @default(true)
  taxEstimatesEnabled        Boolean  @default(true)
  scheduleEnabled            Boolean  @default(true)
  importEnabled              Boolean  @default(true)
  maintenanceMode            Boolean  @default(false)
  maintenanceMessage         String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  users User[]
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  password               String
  name                   String
  role                   String    @default("EMPLOYEE") // EMPLOYEE | MANAGER | ADMIN
  isActive               Boolean   @default(true)
  companyId              String?
  managerId              String?
  mustResetPassword      Boolean   @default(false)
  hourlyRate             Float     @default(0)
  overtimeRate           Float     @default(1.5)
  overtimeThresholdHours Float     @default(40)
  workweekStartDay       Int       @default(0)
  timeRoundingInterval   Int       @default(5)
  profileImage           String?
  payPeriodType          String    @default("monthly")
  payPeriodEndDay        Int       @default(10)
  paycheckAdjustment     Float     @default(0)
  state                  String?
  stateTaxRate           Float?
  filingStatus           String    @default("single")
  weeklySchedule         String?
  timezone               String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  company     Company?    @relation(fields: [companyId], references: [id])
  manager     User?       @relation("ManagerReports", fields: [managerId], references: [id])
  reports     User[]      @relation("ManagerReports")
  timeEntries TimeEntry[]
  payPeriods  PayPeriodRecord[]
  timesheets  Timesheet[]
  correctionRequests CorrectionRequest[] @relation("EmployeeCorrections")
  reviewedCorrections CorrectionRequest[] @relation("ReviewedCorrections")
  auditLogsAsActor AuditLog[] @relation("AuditActor")
  invitationsSent Invitation[] @relation("InvitedBy")
}

model Invitation {
  id          String   @id @default(cuid())
  email       String
  role        String   @default("EMPLOYEE")
  companyId   String
  tokenHash   String   @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String?
  createdAt   DateTime @default(now())

  invitedBy User? @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([email])
}

model TimeEntry {
  id                String    @id @default(cuid())
  userId            String
  companyId         String?
  clockIn           DateTime
  clockOut          DateTime?
  totalBreakMinutes Int       @default(0)
  notes             String?
  isManualEntry     Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  breaks Break[]

  @@index([userId])
  @@index([clockIn])
  @@index([companyId])
}

model Break {
  id          String    @id @default(cuid())
  timeEntryId String
  breakType   String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  timeEntry TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)

  @@index([timeEntryId])
}

/// Legacy pay period totals model (kept for compatibility)
model PayPeriodRecord {
  id         String   @id @default(cuid())
  userId     String
  startDate  DateTime
  endDate    DateTime
  totalHours Float    @default(0)
  grossPay   Float    @default(0)
  netPay     Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, startDate, endDate])
  @@index([userId])
  @@map("PayPeriod")
}

model Timesheet {
  id             String    @id @default(cuid())
  userId         String
  companyId      String?
  periodStart    DateTime
  periodEnd      DateTime
  status         String    @default("OPEN") // OPEN | SUBMITTED | APPROVED | REJECTED | LOCKED
  submittedAt    DateTime?
  submittedById  String?
  approvedAt     DateTime?
  approvedById   String?
  rejectedAt     DateTime?
  rejectedById   String?
  rejectionReason String?
  lockedAt       DateTime?
  lockedById     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart, periodEnd])
  @@index([userId])
  @@index([status])
  @@index([companyId])
}

model CorrectionRequest {
  id              String    @id @default(cuid())
  employeeId      String
  companyId       String?
  timeEntryId     String?
  timesheetId     String?
  requestedChange String
  reason          String
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED | APPLIED
  reviewedById    String?
  reviewNotes     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee   User  @relation("EmployeeCorrections", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReviewedCorrections", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
}

model AuditLog {
  id             String   @id @default(cuid())
  actorUserId    String?
  actorRole      String?
  companyId      String?
  targetUserId   String?
  entityType     String
  entityId       String?
  action         String
  previousValues String?
  newValues      String?
  reason         String?
  requestId      String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@index([companyId])
}

/// Legacy admin audit (kept; new writes use AuditLog)
model AdminAuditLog {
  id             String   @id @default(cuid())
  adminSubject   String
  affectedUserId String
  action         String
  previousValues String?
  newValues      String?
  createdAt      DateTime @default(now())

  @@index([affectedUserId])
  @@index([createdAt])
}
