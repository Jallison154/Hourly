# SQLite database (relative to backend working directory)
DATABASE_URL="file:./prisma/dev.db"

# JWT signing secret — required, min 32 chars
# Generate: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Admin dashboard credentials (use ONE of these)
# Plain password (compared with timing-safe equality). Prefer hash in production.
ADMIN_PASSWORD="change-me-to-a-strong-password"
# Or bcrypt hash: ADMIN_PASSWORD_HASH="$2a$10$..."

# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated browser origins allowed for CORS.
# Required in production. Requests with no Origin (Capacitor/mobile) are still allowed.
# Example: ALLOWED_ORIGINS=https://hourly.example.com,http://192.168.1.10:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
